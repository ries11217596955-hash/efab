{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Builder Module Inventory",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "modules",
    "validators",
    "contracts",
    "packs",
    "workflows",
    "counts",
    "missing_surfaces"
  ],
  "properties": {
    "schema_version": {
      "const": "AGENT_BUILDER_MODULE_INVENTORY_V1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "collection_status": {
      "enum": [
        "prepared_not_run",
        "collected"
      ]
    },
    "modules": {
      "type": "array"
    },
    "validators": {
      "type": "array"
    },
    "contracts": {
      "type": "array"
    },
    "packs": {
      "type": "array"
    },
    "workflows": {
      "type": "array"
    },
    "counts": {
      "type": "object"
    },
    "missing_surfaces": {
      "type": "array"
    }
  }
}
