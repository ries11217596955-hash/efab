{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "schema_id": "AGENT_PROGRAM_SCHEMA_V1",
  "title": "Agent Production Program Schema v1",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "program_id",
    "agent_id",
    "agent_name",
    "purpose",
    "owner_visible_goal",
    "input_contract",
    "output_contract",
    "required_files",
    "validation_requirements",
    "github_action_required",
    "github_action_name",
    "artifact_name",
    "acceptance_criteria",
    "forbidden_scope"
  ],
  "properties": {
    "program_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_id": {
      "type": "string",
      "minLength": 1
    },
    "agent_name": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "owner_visible_goal": {
      "type": "string",
      "minLength": 1
    },
    "input_contract": {
      "type": "object",
      "description": "Required input shape, fields, allowed values, and validation notes."
    },
    "output_contract": {
      "type": "object",
      "description": "Required output shape, fields, status markers, and handoff notes."
    },
    "required_files": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "validation_requirements": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "github_action_required": {
      "type": "boolean"
    },
    "github_action_name": {
      "type": "string"
    },
    "artifact_name": {
      "type": "string"
    },
    "acceptance_criteria": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    },
    "forbidden_scope": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  }
}
