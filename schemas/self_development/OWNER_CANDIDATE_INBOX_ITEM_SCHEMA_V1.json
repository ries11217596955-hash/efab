{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Owner Candidate Inbox Item V1",
  "type": "object",
  "required": [
    "candidate_id",
    "title",
    "source_type",
    "provenance",
    "intended_capability",
    "risk_notes",
    "acceptance_expectation"
  ],
  "properties": {
    "candidate_id": { "type": "string" },
    "title": { "type": "string" },
    "source_type": { "type": "string" },
    "provenance": { "type": "string" },
    "intended_capability": { "type": "string" },
    "risk_notes": { "type": "string" },
    "acceptance_expectation": { "type": "string" },
    "proposed_files": {
      "type": "array",
      "items": { "type": "string" }
    },
    "owner_notes": { "type": "string" }
  },
  "additionalProperties": true
}
