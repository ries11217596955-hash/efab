{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Agent Builder Self Describe Report",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "schema_version",
    "generated_at_utc",
    "answers",
    "source_self_model",
    "evidence_policy"
  ],
  "properties": {
    "schema_version": {
      "const": "AGENT_BUILDER_SELF_DESCRIBE_REPORT_V1"
    },
    "generated_at_utc": {
      "type": "string"
    },
    "collection_status": {
      "enum": [
        "prepared_not_run",
        "collected"
      ]
    },
    "answers": {
      "type": "object",
      "required": [
        "who_is_builder",
        "what_repo_is_this",
        "current_capability",
        "queue_state",
        "major_systems_exist",
        "major_systems_missing",
        "agent_like_products_evidenced",
        "proofs_reports_supporting_claims",
        "what_should_be_built_next",
        "what_should_not_be_done_next"
      ]
    },
    "source_self_model": {
      "type": "string"
    },
    "evidence_policy": {
      "type": "object"
    }
  }
}
