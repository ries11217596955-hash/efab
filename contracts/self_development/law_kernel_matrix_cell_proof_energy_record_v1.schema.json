{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "ef.contracts.self_development.law_kernel_matrix_cell_proof_energy_record.v1",
  "title": "Law Kernel Matrix Cell Proof Energy Record V1",
  "type": "object",
  "required": [
    "record_id",
    "schema_version",
    "created_at",
    "parent_task",
    "gap",
    "matrix_cell",
    "law_bindings",
    "proof_energy",
    "evidence",
    "decision",
    "return_to_parent_task"
  ],
  "properties": {
    "record_id": {
      "type": "string",
      "minLength": 8
    },
    "schema_version": {
      "const": "law_kernel_matrix_cell_proof_energy_record.v1"
    },
    "created_at": {
      "type": "string"
    },
    "parent_task": {
      "type": "string",
      "minLength": 3
    },
    "gap": {
      "type": "object",
      "required": ["gap_id", "gap_type", "why_this_gap_matters"],
      "properties": {
        "gap_id": { "type": "string" },
        "gap_type": {
          "enum": [
            "concept_gap",
            "procedure_gap",
            "requirement_gap",
            "organ_gap",
            "proof_gap",
            "source_gap",
            "safety_gap",
            "mode_gap"
          ]
        },
        "why_this_gap_matters": { "type": "string" }
      },
      "additionalProperties": false
    },
    "matrix_cell": {
      "type": "object",
      "required": ["cell_id", "layer", "target_capability", "source_kind", "status"],
      "properties": {
        "cell_id": { "type": "string" },
        "layer": {
          "enum": ["atom", "molecule", "organ", "system", "head", "organism"]
        },
        "target_capability": { "type": "string" },
        "source_kind": {
          "enum": [
            "accepted_atom",
            "internal_reference",
            "self_map",
            "protected_control",
            "school",
            "governed_material",
            "external_candidate",
            "owner"
          ]
        },
        "status": {
          "enum": [
            "candidate",
            "sandbox_pass",
            "validator_pass",
            "proof_pass",
            "validated_pending_acceptance",
            "accepted_local",
            "quarantined",
            "rollback_required"
          ]
        }
      },
      "additionalProperties": false
    },
    "law_bindings": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["law_id", "requirement", "pass_condition", "current_status"],
        "properties": {
          "law_id": { "type": "string" },
          "requirement": { "type": "string" },
          "pass_condition": { "type": "string" },
          "current_status": {
            "enum": ["pending", "pass", "fail"]
          }
        },
        "additionalProperties": false
      }
    },
    "proof_energy": {
      "type": "object",
      "required": [
        "memory_proof",
        "use_proof",
        "return_proof",
        "startup_visibility",
        "validation_command"
      ],
      "properties": {
        "memory_proof": { "type": "string" },
        "use_proof": { "type": "string" },
        "return_proof": { "type": "string" },
        "startup_visibility": { "type": "string" },
        "validation_command": { "type": "string" }
      },
      "additionalProperties": false
    },
    "evidence": {
      "type": "object",
      "required": ["repo_path", "branch", "head", "files_created", "validators_run"],
      "properties": {
        "repo_path": { "type": "string" },
        "branch": { "type": "string" },
        "head": { "type": "string" },
        "files_created": {
          "type": "array",
          "items": { "type": "string" }
        },
        "validators_run": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": false
    },
    "decision": {
      "type": "object",
      "required": ["status", "reason"],
      "properties": {
        "status": {
          "enum": [
            "candidate",
            "validated_pending_acceptance",
            "accepted_local",
            "quarantined",
            "rollback_required",
            "owner_decision_required"
          ]
        },
        "reason": { "type": "string" }
      },
      "additionalProperties": false
    },
    "return_to_parent_task": {
      "type": "string",
      "minLength": 3
    }
  },
  "additionalProperties": false
}
