{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "manual_scout_pass.schema.json",
  "title": "Manual Scout Pass",
  "type": "object",
  "required": [
    "scout_pass_id",
    "created_at",
    "created_by",
    "purpose",
    "candidates",
    "cut_list"
  ],
  "properties": {
    "scout_pass_id": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string"
    },
    "created_by": {
      "type": "string",
      "minLength": 1
    },
    "purpose": {
      "type": "string",
      "minLength": 1
    },
    "candidates": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/material_candidate"
      }
    },
    "cut_list": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "$defs": {
    "material_candidate": {
      "type": "object",
      "required": [
        "material_id",
        "name",
        "material_type",
        "source_url",
        "source_origin",
        "provenance_status",
        "license_status",
        "security_status",
        "usage_mode",
        "status",
        "risk_level",
        "owner_approval_required",
        "notes"
      ],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
