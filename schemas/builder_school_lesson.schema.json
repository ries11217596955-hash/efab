{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "builder_school_lesson.schema.json",
  "title": "Builder School Lesson",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "lesson_id",
    "title",
    "objective",
    "expected_outputs",
    "allowed_actions",
    "failure_policy"
  ],
  "properties": {
    "lesson_id": {
      "type": "string",
      "minLength": 1
    },
    "title": {
      "type": "string",
      "minLength": 1
    },
    "objective": {
      "type": "string",
      "minLength": 1
    },
    "inputs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "expected_outputs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "allowed_actions": {
      "type": "array",
      "items": {
        "enum": [
          "read_repo",
          "read_route_lock",
          "parse_schema",
          "write_runtime",
          "observe_live_surface",
          "commit",
          "push",
          "branch_switch",
          "accepted_repo_mutation",
          "protected_state_mutation"
        ]
      }
    },
    "failure_policy": {
      "type": "object",
      "additionalProperties": true,
      "required": [
        "continue_batch",
        "quarantine_on_safety_violation"
      ],
      "properties": {
        "continue_batch": {
          "const": true
        },
        "quarantine_on_safety_violation": {
          "const": true
        }
      }
    },
    "validator_expectations": {
      "type": "object",
      "additionalProperties": true
    }
  }
}
