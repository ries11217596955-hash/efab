    "result_contract": {
      "type": "object"
    },
    "simulation_performed": {
      "type": "boolean"
    },
    "real_items_executed": {
      "const": false
    },
    "next_allowed_step": {
      "const": "PHASE106_SCALE_TRIAL_PROMOTION_GATE_AND_ROUTE_LOCK_REFRESH_V1"
    }
